# .env.example
# Copy to .env.local via `vercel env pull .env.local` — do not edit by hand.
# See lib/env.ts for the authoritative zod schema.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
TOKEN_ENCRYPTION_KEY_V1=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Ingestion pipeline — required for cron route auth.
# Generate a production value with: openssl rand -hex 32
# This placeholder lets .env.local copies parse in dev; replace before deploy.
CRON_SECRET=placeholder-replace-with-openssl-rand-hex-32

# Reserved for sub-projects — safe to omit during Foundation:
# GEMINI_API_KEY=

# Rescore drain mode: 'true' switches the rescore cron from monthly to daily cadence
# during a major prompt-version migration. Toggle back to 'false' (or unset) when the
# version-mismatched row count drops below ~100. Accepted values: 'true' | 'false' | unset.
RESCORE_DRAIN_MODE=
